<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.techshop.inventorypos.controller.views.DashboardController"
      spacing="20" styleClass="content-area" VBox.vgrow="ALWAYS">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Dashboard" styleClass="page-title"/>

    <HBox spacing="16">
        <VBox styleClass="stat-card, stat-card-blue" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="TOTAL PRODUCTS" styleClass="stat-label"/>
            <Label fx:id="totalProductsLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-red" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="LOW STOCK ITEMS" styleClass="stat-label"/>
            <Label fx:id="lowStockLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-green" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="TOTAL SALES" styleClass="stat-label"/>
            <Label fx:id="totalSalesLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-purple" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="TOTAL REVENUE (RM)" styleClass="stat-label"/>
            <Label fx:id="totalRevenueLabel" text="0.00" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <VBox styleClass="panel-card" spacing="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <Label text="Low Stock Alerts" styleClass="panel-title"/>
        <ListView fx:id="lowStockList" prefHeight="220"/>
        <HBox fx:id="paginationContainer" alignment="CENTER"/>
    </VBox>

</VBox>
